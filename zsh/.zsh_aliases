# This file is sourced by .zshrc

# Most used commands
alias ..="cd ../"
alias ...="cd ../; cd../;"
alias g="git"
alias lg="lazygit"
alias h="cd ~"
if [[ "$OSTYPE" == "darwin"* ]]; then
  alias l="ls -lLAhFG"
  alias ll="ls -lLAhFG"
  alias la="ls -AhFG"
  alias o="open"
else
  alias l="ls -lLAhF --color=auto"
  alias ll="ls -lLAhF --color=auto"
  alias la="ls -AhF --color=auto"
fi
alias r="ranger"
alias v="nvim"
if [[ "$OSTYPE" == "darwin"* ]]; then
  alias cb="pbcopy"
elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
  alias cb="xclip -selection clipboard"
fi
alias cp="cp -v"
alias mv="mv -v"
alias move="mv -v"
alias mkdir="mkdir -pv"

# Common directories
alias dev="cd ~/Developer"
if [[ "$OSTYPE" == "darwin"* ]]; then
  alias docs="cd ~/Documents"
  alias desk="cd ~/Desktop"
  alias pics="cd ~/Pictures"
  alias apps="cd ~/Applications"
fi


# Shortened commands
alias python="python3"
alias pip="pip3"
alias tf="terraform"
alias mux="tmuxinator"
if [[ "$OSTYPE" == "darwin"* ]]; then
  alias caff="caffeinate"
fi
alias shop="shopify"

# Complex commands
alias tfapply="tf apply -no-color | tee -a ./terraform-apply.log"
alias diff='command -v colordiff >/dev/null 2>&1 && colordiff || diff'
alias brew-save="brew bundle dump --file=~/Developer/dotfiles/brew/Brewfile"
fly-start() {
  fly machine start $(fly machine list -a "$1" -q | head -n 1) -a "$1"
}

# Docker shortcuts
alias dc="docker compose"
alias dce="docker compose exec"
alias dcu="docker compose up -d"
alias dcd="docker compose down"
alias dcb="docker compose build"
alias dcr="docker compose run"
alias dcl="docker compose logs -f"
alias dcul="docker compose up -d && docker compose logs -f"
alias dcrebuild="docker compose down && docker compose build && docker compose up -d && docker compose logs -f"

# Network info
alias pscan="nmap 0.0.0.0"
alias wanip="curl ifconfig.me"
alias lanip="ifconfig | grep -Eo 'inet (addr:)?([0-9]*\.){3}[0-9]*' | grep -Eo '([0-9]*\.){3}[0-9]*' | grep -v '127.0.0.1' | grep -v '172.'"
